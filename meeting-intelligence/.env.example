# Copy to .env and adjust. All values are optional; defaults run a zero-key demo.

LOG_LEVEL=INFO
LOG_JSON=true

# --- Seam selection ---------------------------------------------------------
# Demo/CI profile (no keys, no downloads):
#   EMBEDDER_BACKEND=fake  VECTOR_STORE_BACKEND=memory  RERANKER_BACKEND=noop  LLM_BACKEND=echo
# Recommended real profile:
#   EMBEDDER_BACKEND=local VECTOR_STORE_BACKEND=chroma RERANKER_BACKEND=noop LLM_BACKEND=openai
# Reranker options: noop (default — the eval showed local/cohere didn't beat the
#   bi-encoder on this corpus), local (keyless cross-encoder), cohere (hosted).
EMBEDDER_BACKEND=local
VECTOR_STORE_BACKEND=chroma
RERANKER_BACKEND=noop
LLM_BACKEND=echo

# --- Embedding --------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Vector store -----------------------------------------------------------
CHROMA_PATH=./.chroma
COLLECTION_NAME=meeting_turns

# --- Retrieval knobs --------------------------------------------------------
RETRIEVE_TOP_N=20
FINAL_TOP_K=4
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Ingestion / conversation ----------------------------------------------
MAX_CHUNK_CHARS=1200
REDACTION_ENABLED=true
EXTRACTION_ENABLED=true
MAX_HISTORY_TURNS=6

# --- Keys (only needed for the corresponding backend) -----------------------
COHERE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
